APP_NAME=AI DevOps & Code Review Automation Platform
APP_ENV=development
DEMO_MODE=true
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./devops_review.db
USE_CELERY=true
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:5173

# GitHub App live integration
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=change-webhook-secret
GITHUB_API_URL=https://api.github.com

# AI provider: mock or openai_compatible
AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=60

# Analyzer execution
ANALYZER_TIMEOUT_SECONDS=120
ANALYZER_EXECUTION_ENABLED=false
RUN_PROJECT_TESTS=false
MAX_DIFF_CHARACTERS=200000
WORKSPACE_ROOT=./workspaces
